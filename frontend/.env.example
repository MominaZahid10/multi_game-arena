# Backend API base URL (include /api/v1 suffix)
# Example for a Hugging Face Space: https://your-space.hf.space/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket base URL (optional – if omitted, derived from VITE_API_URL)
# Example: wss://your-space.hf.space
# VITE_WS_URL=ws://localhost:8000
